{
    "address": "0.0.0.0",
    "port": 465,
    "use_ssl": true,
    "allow_insecure": true,
    "insecure_port": 25,
    "certFile": "config/cert.pem",
    "keyFile": "config/key.pem",
    "dhFile": "config/dh.pem",
    "maxMessageSize": 1048576,
    "maxConnections": 1000,
    "io_thread_count": 4,
    "worker_thread_count": 8,
    "ssl_in_worker": false,
    "use_database": false,
    "connection_timeout": 300,
    "read_timeout": 60,
    "write_timeout": 60,
    "require_auth": true,
    "max_auth_attempts": 3,
    "log_level": "info",
    "log_file": "logs/mail_server.log"
}