{
  "address": "0.0.0.0",
  "system_name": "scut-email-smtp",
  "system_domain": "scut.email",

  "listeners": [
    { "type": "tcp", "port": 25,  "auth_policy": "off" },
    { "type": "ssl", "port": 465, "auth_policy": "on" },
    { "type": "tcp", "port": 587, "auth_policy": "on" }
  ],

  "certFile": "crt/server.crt",
  "keyFile": "crt/server.key",

  "use_database": true,
  "db_config_file": "db_config.json",

  "maxMessageSize": 10485760,
  "maxConnections": 100000,

  "io_thread_count": 12,
  "worker_thread_count": 4,

  "connection_timeout": 300,
  "read_timeout": 60,
  "write_timeout": 60,
  "max_auth_attempts": 3,

  "perf_mode": true,

  "log_level": "info",
  "log_to_console": false,
  "log_to_file": false,
  "log_file": "../logs/server.log",

  "mail_storage_path": "../mail/",
  "attachment_storage_path": "../attachments/",
  "persist_min_available_memory_mb": 0,
  "inbound_ack_mode": "after_enqueue",

  "inbound_auth_policy": "off",
  "inbound_spf_mode": "hard",
  "inbound_dkim_mode": "soft",
  "inbound_dmarc_mode": "soft",

  "dnsbl_enabled": true,
  "intrusion_detection_enabled": true,
  "intrusion_ban_threshold": 5,

  "outbound_helo_domain": "smtp.scut.email",
  "outbound_mail_from_domain": "scut.email",
  "outbound_rewrite_header_from": true,
  "outbound_dkim_enabled": true,
  "outbound_dkim_selector": "202407",
  "outbound_dkim_domain": "scut.email",
  "outbound_dkim_private_key_file": "dkim/202407.scut.email.private.pem",
  "outbound_ports": [465],
  "outbound_max_attempts": 8
}
