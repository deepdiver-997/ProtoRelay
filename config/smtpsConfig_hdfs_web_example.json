{
  "address": "0.0.0.0",
  "enable_ssl": true,
  "ssl_port": 465,
  "enable_tcp": true,
  "tcp_port": 25,
  "allow_insecure": true,
  "insecure_port": 25,
  "certFile": "crt/server.crt",
  "keyFile": "crt/server.key",
  "dhFile": "",
  "maxMessageSize": 1048576,
  "maxConnections": 1000,
  "io_thread_count": 8,
  "worker_thread_count": 8,
  "use_database": true,
  "db_config_file": "db_config.json",
  "connection_timeout": 300,
  "read_timeout": 60,
  "write_timeout": 60,
  "require_auth": false,
  "max_auth_attempts": 3,
  "system_name": "mail-system-hdfs",
  "system_domain": "mail.hgmail.xin",
  "outbound_helo_domain": "mail.hgmail.xin",
  "outbound_mail_from_domain": "mail.hgmail.xin",
  "outbound_rewrite_header_from": true,
  "outbound_dkim_enabled": true,
  "outbound_dkim_selector": "default",
  "outbound_dkim_domain": "mail.hgmail.xin",
  "outbound_dkim_private_key_file": "crt/dkim_private.pem",
  "outbound_ports": [25],
  "outbound_max_attempts": 8,
  "log_level": "info",
  "log_to_console": true,
  "log_to_file": true,
  "log_file": "../logs/server.log",
  "storage_provider": "hdfs_web",
  "hdfs_endpoint": "http://127.0.0.1:9870",
  "hdfs_base_path": "/user/hdfs/mail-system-v8",
  "hdfs_user": "hdfs",
  "hdfs_timeout_ms": 5000,
  "hdfs_replication": 2,
  "mail_storage_path": "../mail/",
  "attachment_storage_path": "../attachments/"
}
