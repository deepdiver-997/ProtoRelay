{
  "address": "0.0.0.0",
  "system_name": "scut-email-imap",
  "system_domain": "scut.email",

  "listeners": [
    { "type": "tcp", "port": 143, "auth_policy": "off" },
    { "type": "ssl", "port": 993, "auth_policy": "on" }
  ],

  "certFile": "crt/server.crt",
  "keyFile": "crt/server.key",

  "use_database": true,
  "db_config_file": "db_config.json",

  "maxMessageSize": 10485760,
  "maxConnections": 100000,

  "io_thread_count": 4,
  "worker_thread_count": 4,

  "connection_timeout": 300,
  "read_timeout": 60,
  "write_timeout": 60,
  "max_auth_attempts": 3,

  "perf_mode": true,

  "metrics_enabled": false,

  "log_level": "info",
  "log_to_console": true,
  "log_to_file": false,
  "log_file": "/tmp/logs/imap-server.log",

  "storage": {
    "provider": "local",
    "local": {
      "mail_path": "/tmp/mail",
      "attachment_path": "/tmp/attachments"
    }
  },
  "persist_min_available_memory_mb": 0,
  "inbound_ack_mode": "after_enqueue",

  "inbound_auth_policy": "off",
  "inbound_spf_mode": "off",
  "inbound_dkim_mode": "off",
  "inbound_dmarc_mode": "off",

  "dnsbl_enabled": false,
  "intrusion_detection_enabled": false,

  "outbound": {
    "helo_domain": "smtp.scut.email",
    "mail_from_domain": "scut.email",
    "rewrite_header_from": false,
    "max_attempts": 1,
    "ports": [465],
    "dkim": {
      "enabled": false
    }
  }
}
