{
  "address": "0.0.0.0",
  "system_name": "mail-system-imap",
  "system_domain": "scut.email",

  "listeners": [
    { "type": "ssl", "port": 993, "auth_policy": "on" },
    { "type": "tcp", "port": 143, "auth_policy": "on" }
  ],

  "certFile": "crt/server.crt",
  "keyFile": "crt/server.key",

  "use_database": true,
  "db_config_file": "db_config.json",

  "maxConnections": 1000,
  "connection_timeout": 1800,
  "read_timeout": 600,
  "write_timeout": 600,
  "max_auth_attempts": 3,

  "log_level": "info",
  "log_to_console": true,
  "log_to_file": true,
  "log_file": "../logs/imap_server.log",

  "storage_provider": "local",
  "mail_storage_path": "../mail/",
  "attachment_storage_path": "../attachments/"
}
